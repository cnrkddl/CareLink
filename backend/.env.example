# =============================================
# CareLink 백엔드 환경변수 설정 예시
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요
# =============================================

# OpenAI API (챗봇 + OCR LLM 파싱에 사용)
OPENAI_API_KEY=sk-...

# 카카오 OAuth2 앱 설정
# https://developers.kakao.com 에서 발급
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret   # 없으면 비워도 됨
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
KAKAO_ADMIN_KEY=your_kakao_admin_key           # 연결해제(unlink)에 사용

# 프론트엔드 설정
FRONTEND_REDIRECT_URL=http://localhost:3000/
FRONTEND_ORIGIN=http://localhost:3000

# 쿠키 설정 (로컬 개발 기본값)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=           # 로컬에서는 비워둠
